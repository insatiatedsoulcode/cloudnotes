# Root-level .dockerignore — used when frontend builds with context: . (project root)
# Keeps the build context small: only frontend/ and nginx/ are needed.

.git
.github

# Backend artifacts — not needed for the frontend build
backend/.venv
backend/uploads
backend/__pycache__
backend/.pytest_cache
backend/tests
backend/*.pyc

# Frontend dev artifacts
frontend/node_modules
frontend/.vite

# Docs / misc
*.md
SRS*.md
CHANGELOG.md
README.md
